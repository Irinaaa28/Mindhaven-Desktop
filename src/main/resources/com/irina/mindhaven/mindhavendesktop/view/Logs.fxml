<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.irina.mindhaven.mindhavendesktop.controllers.LogsController">

    <Label text="User Logs" style="-fx-font-size: 22px; -fx-font-weight: bold;" />

    <TableView fx:id="logsTable" prefHeight="300" prefWidth="500">
        <columns>
            <TableColumn text="ID" prefWidth="150" />
            <TableColumn text="Action" prefWidth="150" />
            <TableColumn text="IP Address" prefWidth="150" />
            <TableColumn text="User Agent" prefWidth="150" />
            <TableColumn text="Timestamp" prefWidth="150" />
        </columns>
    </TableView>

    <Button text="Back" prefWidth="200" onAction="#goBack" />
</VBox>
