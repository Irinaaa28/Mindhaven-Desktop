<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.irina.mindhaven.mindhavendesktop.ratelimit.RateLimitController"
      alignment="CENTER"
      spacing="20">

    <Label text="RATE LIMIT EXCEEDED"
           style="-fx-font-size: 24px; -fx-text-fill: red;" />

    <Label text="Too many requests were sent to the server." />

    <Label text="Please try again later." />

    <Button text="Back to Login"
            onAction="#goToLogin"/>

</VBox>