<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.irina.mindhaven.mindhavendesktop.controllers.DashboardController">

    <Label text="Dashboard" style="-fx-font-size: 22px; -fx-font-weight: bold;" />

    <Button text="View Users" prefWidth="200" onAction="#openUsers"/>
    <Button text="View Logs" prefWidth="200" onAction="#openLogs"/>
    <Button text="Logout" prefWidth="200" onAction="#handleLogout"/>

</VBox>
