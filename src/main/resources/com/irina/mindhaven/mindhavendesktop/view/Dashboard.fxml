<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<?import javafx.geometry.Insets?>
<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.irina.mindhaven.mindhavendesktop.home.DashboardController">
    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

    <Label fx:id="loginSuccessLabel" visible="false" managed="false" style="-fx-text-fill: green; -fx-font-size: 13px; -fx-font-weight: bold;" />
    <Label text="Dashboard" style="-fx-font-size: 22px; -fx-font-weight: bold;" />

    <Button text="Create Rule" prefWidth="200" onAction="#handleCreateRule"/>
    <Button text="My Rules" prefWidth="200" onAction="#handleMyRules"/>
    <Button fx:id="rulesButton" text="All Rules" prefWidth="200" onAction="#openRules" visible="false" managed="false"/>
    <Button fx:id="usersButton" text="View Users" prefWidth="200" onAction="#openUsers" visible="false" managed="false"/>
    <Button fx:id="logsButton" text="View Logs" prefWidth="200" onAction="#openLogs" visible="false" managed="false"/>
    <Button text="Logout" prefWidth="200" onAction="#handleLogout"/>

</VBox>
